# Environment variables for the Jolly Phone site.
# Names only — never commit real values. Set these in Vercel → Settings →
# Environment Variables. Copy to .env.local for local dev (gitignored).

# ——— /api/demo-call — outbound Vapi demo call ———
# Vapi private API key. Server-side only; never expose to the client.
VAPI_API_KEY=
# Id of a number you own in Vapi — used as the caller ID.
VAPI_PHONE_NUMBER_ID=
# The demo/showcase assistant the orb button triggers.
VAPI_DEMO_ASSISTANT_ID=

# Optional demo-call rate limits (defaults: 2 per number/hour, 60 global/hour).
DEMO_MAX_PER_HOUR=
DEMO_MAX_GLOBAL_HOUR=

# ——— /api/contact — Contact Sales form ———
RESEND_API_KEY=
CONTACT_EMAIL_TO=
CONTACT_EMAIL_FROM=
